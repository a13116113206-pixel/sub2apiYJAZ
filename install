#!/usr/bin/env bash
set -Eeuo pipefail

INSTALLER_URL="${INSTALLER_URL:-https://cdn.jsdelivr.net/gh/a13116113206-pixel/sub2apiYJAZ@e6c4f14ccb8618a095fbdbc52a06b541613e5a6c/install_bt_sub2api.sh}"
INSTALLER_PATH="/tmp/install_bt_sub2api.sh"

if [ "$(id -u)" -ne 0 ]; then
  echo "请使用 root 运行，例如：curl -fsSL https://cdn.jsdelivr.net/gh/a13116113206-pixel/sub2apiYJAZ@main/install | sudo bash" >&2
  exit 1
fi

curl -fsSL --connect-timeout 20 -m 120 "${INSTALLER_URL}" -o "${INSTALLER_PATH}"
bash "${INSTALLER_PATH}"
